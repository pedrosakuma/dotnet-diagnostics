<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>DotnetDiagnostics.Cli</RootNamespace>
    <AssemblyName>dotnet-diagnostics</AssemblyName>
    <Description>Standalone one-shot diagnostics CLI for dotnet-diagnostics-mcp. References Core only — no MCP server, HTTP transport, or bearer auth. Attaches to a live .NET process over the diagnostic IPC socket and prints a result table (or the shared DiagnosticResult envelope with --json).</Description>
  </PropertyGroup>

  <!-- Packaging (issue #288): published to NuGet as a .NET global tool. Consumers install
       with `dotnet tool install -g dotnet-diagnostics-cli` and invoke `dotnet-diagnostics-cli`
       from PATH. The PackageId/ToolCommandName intentionally differ from the assembly name
       (`dotnet-diagnostics`) and from the sibling MCP server tool (`dotnet-diagnostics-mcp`)
       so the standalone one-shot CLI and the long-running MCP server stay installable side by
       side. The tool command shim is generated by the SDK when PackAsTool=true. -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>dotnet-diagnostics-cli</ToolCommandName>
    <PackageId>dotnet-diagnostics-cli</PackageId>
    <Authors>pedrosakuma</Authors>
    <Company>pedrosakuma</Company>
    <PackageProjectUrl>https://github.com/pedrosakuma/dotnet-diagnostics</PackageProjectUrl>
    <RepositoryUrl>https://github.com/pedrosakuma/dotnet-diagnostics</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>diagnostics;dotnet;cli;performance;profiling;cpu;gc;eventpipe;heap;dump</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DotnetDiagnostics.Cli.Tests" />
  </ItemGroup>

  <!-- Core reference ONLY. The acceptance bar for the #283 layering seam is that this project
       never references DotnetDiagnostics.Mcp (asserted by NoServerReferenceTests). -->
  <ItemGroup>
    <ProjectReference Include="..\DotnetDiagnostics.Core\DotnetDiagnostics.Core.csproj" />
  </ItemGroup>

</Project>
