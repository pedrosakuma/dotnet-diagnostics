<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>DiagnosedBenchmarks</RootNamespace>
    <AssemblyName>DiagnosedBenchmarks</AssemblyName>
    <!-- BenchmarkDotNet must build in Release and run outside a debugger. -->
    <Optimize>true</Optimize>
    <ServerGarbageCollection>false</ServerGarbageCollection>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
  </ItemGroup>

  <!-- Reference the in-process diagnoser library directly: no shell-out, no CLI on disk.
       The library pulls in dotnet-diagnostics-core transitively. -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\DotnetDiagnostics.BenchmarkDotNet\DotnetDiagnostics.BenchmarkDotNet.csproj" />
  </ItemGroup>

</Project>
