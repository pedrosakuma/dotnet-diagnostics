{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pedrosakuma/dotnet-diagnostics/schemas/diagnostic-scenario-manifest-v1.json",
  "title": "Diagnostic scenario manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "supportedLivePlatforms",
    "reportedSymptom",
    "groundTruth",
    "workload",
    "budget",
    "expectedEvidence",
    "misleadingSignals",
    "temptingWrongHypotheses",
    "acceptableHypotheses",
    "acceptableAttributions",
    "acceptableNextActions",
    "forbiddenConclusions",
    "requiredCausalityPosture"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "supportedLivePlatforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": [ "windows", "linux" ] }
    },
    "reportedSymptom": { "type": "string", "minLength": 1 },
    "groundTruth": { "type": "string", "minLength": 1 },
    "workload": { "$ref": "#/$defs/workload" },
    "budget": { "$ref": "#/$defs/budget" },
    "expectedEvidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/invariant" }
    },
    "misleadingSignals": { "$ref": "#/$defs/stringArray" },
    "temptingWrongHypotheses": { "$ref": "#/$defs/nonEmptyStringArray" },
    "acceptableHypotheses": { "$ref": "#/$defs/nonEmptyStringArray" },
    "acceptableAttributions": { "$ref": "#/$defs/nonEmptyStringArray" },
    "acceptableNextActions": { "$ref": "#/$defs/nonEmptyStringArray" },
    "forbiddenConclusions": { "$ref": "#/$defs/nonEmptyStringArray" },
    "requiredCausalityPosture": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "setup", "activation", "cleanup", "parameters", "warmupMilliseconds", "observationSeconds" ],
      "properties": {
        "setup": { "type": "string", "minLength": 1 },
        "activation": { "type": "string", "minLength": 1 },
        "cleanup": { "type": "string", "minLength": 1 },
        "parameters": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "warmupMilliseconds": { "type": "integer", "minimum": 0 },
        "observationSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "maximumRuntimeSeconds", "maximumEvidenceItems" ],
      "properties": {
        "maximumRuntimeSeconds": { "type": "integer", "minimum": 1 },
        "maximumEvidenceItems": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "invariant": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "id", "kind" ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": [
            "signalPresent",
            "signalBucketMatch",
            "counterComparison",
            "stackFrameMatch",
            "threadOwnerCorrelation"
          ]
        },
        "signal": { "type": "string", "minLength": 1 },
        "metric": { "type": "string", "minLength": 1 },
        "containsAny": { "$ref": "#/$defs/nonEmptyStringArray" },
        "comparison": {
          "enum": [ "greaterThan", "greaterThanOrEqual", "lessThan", "lessThanOrEqual", "equal" ]
        },
        "threshold": { "type": "number" },
        "minimumMatches": { "type": "integer", "minimum": 1 },
        "relation": { "type": "string", "minLength": 1 },
        "ownerWaitReason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
